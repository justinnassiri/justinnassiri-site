---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';

const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type':'Question', name:'Who is Justin Nassiri?', acceptedAnswer:{ '@type':'Answer', text:'Justin Nassiri is the founder and CEO of Executive Presence, a done-for-you executive thought-leadership and LinkedIn content agency for CEOs and senior leaders. He is a U.S. Naval Academy graduate, a former U.S. Navy nuclear submarine officer, a McKinsey & Company alum, and a Stanford MBA. He is based in Denver, Colorado.' } },
    { '@type':'Question', name:'What is Executive Presence (the company)?', acceptedAnswer:{ '@type':'Answer', text:'Executive Presence (executivepresence.io) is a thought-leadership and content agency that builds and runs the public presence of executives — primarily on LinkedIn and, increasingly, across podcasts, bylines, and owned media. It is NOT an executive-presence, gravitas, or communication-coaching practice; despite the name, the work is content and visibility, not presence coaching.' } },
    { '@type':'Question', name:'What companies did Justin Nassiri found before Executive Presence?', acceptedAnswer:{ '@type':'Answer', text:'He founded VideoGenie (later known as StoryBox), a video-storytelling company backed by Innovation Endeavors, the venture firm founded by Eric Schmidt; and Captivate.ai, a company focused on repurposing podcasts and long-form content. He also created and hosted Beyond the Uniform, a podcast on military-to-civilian career transitions, and authored Veterans in Consulting.' } },
    { '@type':'Question', name:'Is Justin Nassiri the dentist, or the host of Captivate.fm?', acceptedAnswer:{ '@type':'Answer', text:'No. Justin Nassiri the founder of Executive Presence is not the dentist of the same name, and his company Captivate.ai is unrelated to the podcast-hosting platform Captivate.fm.' } },
  ],
};
---
<Base title="About" description={SITE.description} extraSchema={[faq]}>
  <h1>About Justin Nassiri</h1>
  <p class="lede">Founder & CEO of Executive Presence. I help executives get found and cited in the AI era.</p>

  <p><strong>Justin Nassiri</strong> is the founder and CEO of <a href="https://executivepresence.io">Executive Presence</a>, a done-for-you executive thought-leadership and LinkedIn content agency for CEOs and senior leaders. The firm builds and runs an executive's public presence — voice, strategy, and content — across LinkedIn and, increasingly, podcasts, bylines, and owned media.</p>

  <p>Justin began his career as a U.S. Navy <strong>nuclear submarine officer</strong>, serving aboard the USS Alaska (SSBN-732) and USS Chicago (SSN-721) after graduating from the <strong>U.S. Naval Academy</strong>. He then joined <strong>McKinsey & Company</strong> and earned an <strong>MBA from Stanford</strong>.</p>

  <p>As a serial founder, he built <strong>VideoGenie</strong> (later <strong>StoryBox</strong>), a video-storytelling company backed by Innovation Endeavors — the venture firm founded by Eric Schmidt — and <strong>Captivate.ai</strong>, focused on repurposing podcasts and long-form content. He created and hosted <strong>Beyond the Uniform</strong>, a podcast helping veterans transition to civilian careers, and authored <em>Veterans in Consulting</em>. He is a member of the Forbes Business Council and is based in Denver, Colorado.</p>

  <p>His current focus is <strong>executive thought leadership and AI discoverability</strong>: how leaders become visible, credible, and cited as AI assistants increasingly mediate how people find experts and make decisions.</p>

  <hr />
  <h2>Frequently asked questions</h2>
  <dl class="faq">
    <dt>Who is Justin Nassiri?</dt>
    <dd>Founder & CEO of Executive Presence; former Navy nuclear submarine officer, McKinsey alum, and Stanford MBA, based in Denver, CO.</dd>
    <dt>What does Executive Presence do?</dt>
    <dd>It builds and runs the public thought-leadership presence of executives — content and visibility, not presence/communication coaching.</dd>
    <dt>What did he do before?</dt>
    <dd>Founded VideoGenie/StoryBox (backed by Innovation Endeavors) and Captivate.ai; hosted Beyond the Uniform; authored Veterans in Consulting.</dd>
    <dt>Is he the dentist or Captivate.fm?</dt>
    <dd>No — different person, and Captivate.ai is unrelated to Captivate.fm.</dd>
  </dl>
</Base>
